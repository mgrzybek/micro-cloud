---
apiVersion: v1
kind: Secret
type: Opaque
data:
  ca.crt: {{bundle_crt_base64}}
metadata:
  name: idp-ca
  namespace: {{namespace}}
---
apiVersion: controlplane.cluster.x-k8s.io/v1alpha1
kind: KamajiControlPlane
metadata:
  name: {{cluster_name}}
  namespace: {{namespace}}
spec:
  dataStoreName: microcloud
  deployment:
    extraVolumes:
      - name: idp-ca
        secret:
          secretName: idp-ca
  apiServer:
    extraArgs:
      - "--oidc-issuer-url={{oidc_url}}"
      - "--oidc-client-id={{oidc_client_id}}"
      - "--oidc-ca-file=/etc/kubernetes/pki/idp/ca.crt"
      - "--oidc-username-claim=preferred_username"
      - "--oidc-groups-claim=groups"
      - "--oidc-username-prefix=oidc:"
      - "--oidc-groups-prefix=oidc:"
    extraVolumeMounts:
        - name: idp-ca
          mountPath: /etc/kubernetes/pki/idp
          readOnly: true
  controllerManager:
    extraArgs:
      - --cloud-provider=external
  addons:
    coreDNS:
      dnsServiceIPs:
      - 172.26.0.10
      imageRepository: "registry.ring0:5000/registry.k8s.io"
  kubelet:
    cgroupfs: systemd
    preferredAddressTypes:
      - ExternalIP
      - InternalIP
      - Hostname
  network:
    serviceType: LoadBalancer
    serviceAnnotations:
      io.cilium/lb-ipam-ips: {{cp_host}}
      tailscale.com/expose: "true"
      tailscale.com/hostname: {{cluster_name}}
    serviceLabels:
      ring0/kaas: "true"
  registry: "registry.{{ ts_suffix }}:443/registry.k8s.io"
  replicas: 1
  version: v1.33.2
---
apiVersion: cluster.x-k8s.io/v1beta1
kind: Cluster
metadata:
  name: {{cluster_name}}
  namespace: {{namespace}}
spec:
  clusterNetwork:
    apiServerPort: 6443
    pods:
      cidrBlocks:
      - 192.168.0.0/16
    services:
      cidrBlocks:
      - 172.26.0.0/16
  controlPlaneEndpoint:
    host: {{cp_host}}
    port: 6443
  controlPlaneRef:
    apiVersion: controlplane.cluster.x-k8s.io/v1alpha1
    kind: KamajiControlPlane
    name: {{cluster_name}}
  infrastructureRef:
    apiVersion: infrastructure.cluster.x-k8s.io/v1beta1
    kind: TinkerbellCluster
    name: {{cluster_name}}
---
apiVersion: infrastructure.cluster.x-k8s.io/v1beta1
kind: TinkerbellCluster
metadata:
  name: {{cluster_name}}
  namespace: {{namespace}}
spec:
  imageLookupBaseRegistry: http://registry.ring0:8080/assets
  controlPlaneEndpoint:
    host: {{cp_host}}
    port: 6443
---
apiVersion: cluster.x-k8s.io/v1beta1
kind: MachineDeployment
metadata:
  labels:
    cluster.x-k8s.io/cluster-name: {{cluster_name}}
    pool: {{machine_pool}}
  name: {{cluster_name}}-{{machine_pool}}
  namespace: {{namespace}}
spec:
  clusterName: {{cluster_name}}
  replicas: 1
  selector:
    matchLabels:
      cluster.x-k8s.io/cluster-name: {{cluster_name}}
      pool: {{machine_pool}}
  template:
    metadata:
      labels:
        cluster.x-k8s.io/cluster-name: {{cluster_name}}
        pool: {{machine_pool}}
    spec:
      bootstrap:
        configRef:
          apiVersion: bootstrap.cluster.x-k8s.io/v1beta1
          kind: KubeadmConfigTemplate
          name: {{cluster_name}}-{{machine_pool}}
      clusterName: {{cluster_name}}
      infrastructureRef:
        apiVersion: infrastructure.cluster.x-k8s.io/v1beta1
        kind: TinkerbellMachineTemplate
        name: ignition-based-installation-kubernetes-worker
      version: v1.33.2
---
apiVersion: infrastructure.cluster.x-k8s.io/v1beta1
kind: TinkerbellMachineTemplate
metadata:
  name: ignition-based-installation-kubernetes-worker
  namespace: {{namespace}}
spec:
  template:
    spec:
      hardwareAffinity:
        required:  # 'required' entries are OR'd
        - labelSelector:
            matchLabels:
              generated-by: machinecfg
              role: Cattle
              status: Staged
              tenant: {{netbox_tenant}}
              model:  {{netbox_model}}
      templateOverride: |-
        version: "0.1"
        name: airgap-template-ignition
        global_timeout: 6000
        tasks:
          - name: "airgap-install-ignition"
            worker: "{{ '{{' }}.device_1}}"
            actions:
              - name: "Dump the custom bundle crt"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                environment:
                  BUNDLE_CRT_BASE64: "{{bundle_crt_base64}}"
                command:
                - sh
                - -c
                - echo $BUNDLE_CRT_BASE64 | base64 -d > /statedir/bundle.crt
              
              - name: "Download kubernetes-1.33.conf"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                command:
                - wget
                - -O
                - /statedir/kubernetes-v1.33.conf
                - http://registry.ring0:8080/assets/flatcar/extensions/kubernetes-v1.33.conf

              - name: "Download noop.conf"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                command:
                - wget
                - -O
                - /statedir/noop.conf
                - http://registry.ring0:8080/assets/flatcar/extensions/noop.conf

              - name: "Download kubernetes-v1.33.2-x86-64.raw"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                command:
                - wget
                - -O
                - /statedir/kubernetes-v1.33.2-x86-64.raw
                - http://registry.ring0:8080/assets/flatcar/extensions/kubernetes-v1.33.2-x86-64.raw

              - name: "Get kubeadm join config from user-data"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                environment:
                  USER_DATA: "{{ '{{' }} .Hardware.UserData | b64enc }}"
                command:
                - sh
                - -c
                - echo $USER_DATA | base64 -d | yq '.write_files[] | select(.path == "/run/kubeadm/kubeadm-join-config.yaml").content' > /statedir/kubeadm-join-config.yaml

              - name: "Get hardware's ignition from vendor-data"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                environment:
                  VENDOR_DATA: "{{ '{{' }} .Hardware.VendorData | b64enc }}"
                command:
                - sh
                - -c
                - echo $VENDOR_DATA | base64 -d > /statedir/vendor-data.json

              - name: "Dump butane system.bu file"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                environment:
                  BUTANE_SYSTEM_BASE64: "{{butane_system_base64}}"
                command:
                - sh
                - -c
                - echo $BUTANE_SYSTEM_BASE64 | base64 -d > /statedir/system.bu

              - name: "Dump butane kubeadm.bu file"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                environment:
                  BUTANE_KUBEADM_BASE64: "{{butane_kubeadm_base64}}"
                command:
                - sh
                - -c
                - echo $BUTANE_KUBEADM_BASE64 | base64 -d > /statedir/kubeadm.bu

              - name: "Dump butane merge.bu file"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                environment:
                  BUTANE_MERGE_BASE64: "{{butane_merge_base64}}"
                command:
                - sh
                - -c
                - echo $BUTANE_MERGE_BASE64 | base64 -d > /statedir/merge.bu

              - name: "Create ignition system.json from system.bu"
                image: "registry.ring0:5000/butane:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                command:
                - butane
                - --strict
                - --files-dir=/statedir
                - /statedir/system.bu
                - --output=/statedir/system.json

              - name: "Create ignition kubeadm.json from kubeadm.bu"
                image: "registry.ring0:5000/butane:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                command:
                - butane
                - --strict
                - --files-dir=/statedir
                - /statedir/kubeadm.bu
                - --output=/statedir/kubeadm.json

              - name: "Create the final ignition.json file from merge.bu"
                image: "registry.ring0:5000/butane:latest"
                volumes:
                - /statedir:/statedir # Stateful volume containing the configuration files (crt, butane and ignition)
                timeout: 600
                command:
                - butane
                - --strict
                - --files-dir=/statedir
                - /statedir/merge.bu
                - --output=/statedir/ignition.json

              - name: "Install flatcar using flatcar-install.sh"
                image: "registry.ring0:5000/flatcar-install:latest"
                volumes:
                - /dev:/dev                          # Needed for accessing the disk so that we can install Flatcar on it.
                - /etc/os-release:/etc/os-release:ro # Needed to skip a warning running flatcar-install.sh
                - /statedir:/statedir                # Stateful volume containing the configuration files (crt, butane and ignition)
                - /tmp:/tmp                          # Bind /tmp instead of writing artifacts in a volume
                timeout: 1200
                command:
                - /bin/flatcar-install.sh
                - -s
                - -i
                - /statedir/ignition.json
                - -b 
                - http://registry.ring0:8080/assets/flatcar

              - name: "Reboot"
                image: registry.ring0:5000/jacobweinstock/waitdaemon:0.2.1
                timeout: 90
                pid: host
                command:
                - reboot
                environment:
                  IMAGE: registry.ring0:5000/library/alpine:latest
                  WAIT_SECONDS: 10
                volumes:
                - /var/run/docker.sock:/var/run/docker.sock
---
apiVersion: bootstrap.cluster.x-k8s.io/v1beta1
kind: KubeadmConfigTemplate
metadata:
  name: {{cluster_name}}-{{machine_pool}}
  namespace: {{namespace}}
spec:
  template:
    spec:
      joinConfiguration:
        nodeRegistration:
          kubeletExtraArgs:
            provider-id: PROVIDER_ID
            feature-gates: KubeletEnsureSecretPulledImages=true,KubeletCrashLoopBackOffMax=true
---
apiVersion: cilium.io/v2alpha1
kind: CiliumLoadBalancerIPPool
metadata:
  name: ring0-kaas-pool-l2
  namespace: kube-system
spec:
  blocks:
  - cidr: {{cp_host}}/32
  serviceSelector:
    matchLabels:
      ring0/kaas: "true"
---
apiVersion: cilium.io/v2alpha1
kind: CiliumL2AnnouncementPolicy
metadata:
  name: ring0-kaas
  namespace: kube-system
spec:
  interfaces:
  - {{announcement_interface}}
  externalIPs: false
  loadBalancerIPs: true